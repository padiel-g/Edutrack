FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=generate-a-random-value-of-at-least-32-characters
JWT_SECRET_KEY=generate-a-different-random-value-of-at-least-32-characters
DATABASE_URL=postgresql://edutrack_app:replace-password@127.0.0.1:5432/edutrack
CORS_ORIGINS=https://edutrack.example.com
FORCE_HTTPS=true
TRUST_PROXY=true
HOST=127.0.0.1
PORT=5000
WAITRESS_THREADS=8
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
JWT_BLOCKLIST_STORAGE_URI=redis://127.0.0.1:6379/1
BACKUP_PATH=C:\EduTrack\backups
BACKUP_RETENTION_DAYS=14
MAX_CONTENT_LENGTH=20971520
MATERIAL_UPLOAD_PATH=C:\EduTrack\uploads\learning-materials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=school@example.com
SMTP_PASSWORD=replace-with-an-email-app-password
SMTP_FROM_EMAIL=school@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=5
